{% extends "base.html.twig" %}

{% block content %}
<section class="ts-hero">
	<div>
		<p class="ts-eyebrow">Relay details</p>
		<h1>{{ Name|default('Router')|e }}</h1>
		<p class="ts-muted">Relay metadata, exit policy, bandwidth history, flags and keys.</p>
	</div>
	<a href="index.php" class="ts-button ts-button-secondary" title="Return to the router list"><i class="ti ti-list-details" aria-hidden="true"></i>Routers</a>
</section>

{% if error|default('') %}
<section class="ts-card ts-status-card">
	<div class="ts-status-icon ts-status-icon-warn"><i class="ti ti-alert-triangle" aria-hidden="true"></i></div>
	<div>
		<h2>Error</h2>
		<p class="ts-muted">{{ error|e }}</p>
	</div>
</section>
{% else %}
<div class="ts-grid-two">
	<section class="ts-card">
		<h2>General information</h2>
		<dl class="ts-description-list">
			<div><dt>Router name</dt><dd>{{ Name|e }}</dd></div>
			<div><dt>Fingerprint</dt><dd>{{ Fingerprint_formatted|e }}</dd></div>
			<div><dt>Contact</dt><dd>{% if Contact is not null %}{{ Contact|e }}{% else %}None Given{% endif %}</dd></div>
			<div><dt>IP address</dt><dd>{{ IP|e }}</dd></div>
			<div><dt>Hostname</dt><dd>{% if Hostname == IP %}Unavailable{% else %}{{ Hostname|e }}{% endif %}</dd></div>
			<div><dt>ORPort</dt><dd>{{ ORPort|e }}</dd></div>
			<div><dt>DirPort</dt><dd>{% if DirPort == 0 %}None{% else %}{{ DirPort|e }}{% endif %}</dd></div>
			<div><dt>Country</dt><dd>{% if CountryCode is not null %}<span class="flag flag-country-{{ CountryCode|lower }}"></span> {{ CountryCode|e }}{% else %}Unknown{% endif %}</dd></div>
			<div><dt>Platform</dt><dd>{{ Platform|e }}</dd></div>
			<div><dt>Last descriptor</dt><dd>{{ LastDescriptorPublished|e }}</dd></div>
			<div><dt>Current uptime</dt><dd>{% if Uptime > -1 %}{{ uptime_days }} d {{ uptime_hours }} h {{ uptime_minutes }} m {{ uptime_seconds }} s{% else %}Not Available{% endif %}</dd></div>
			<div><dt>Bandwidth</dt><dd>{{ Bandwidth_MAX }} / {{ Bandwidth_BURST }} / {{ Bandwidth_OBSERVED }} Bps</dd></div>
		</dl>
		<details class="ts-subdetails">
			<summary>Additional OR addresses and family</summary>
			<h3>Additional OR addresses</h3>
			{% if ORAddresses is empty %}
				<p class="ts-muted">None</p>
			{% else %}
				<ul class="ts-inline-list">
				{% for item in ORAddresses %}
					<li>{% if WHOISPath %}<a href="{{ (WHOISPath ~ item.address)|e }}">{{ item.address|e }}</a>{% else %}{{ item.address|e }}{% endif %}:{{ item.port }}</li>
				{% endfor %}
				</ul>
			{% endif %}
			<h3>Family</h3>
			{% if Family_DATA_ARRAY is empty %}
				<p class="ts-muted">No info given</p>
			{% else %}
				<ul class="ts-inline-list">
				{% for member in Family_DATA_ARRAY %}<li>{{ member|e }}</li>{% endfor %}
				</ul>
			{% endif %}
		</details>
	</section>

	<section class="ts-card">
		<h2>Exit policy</h2>
		<pre class="ts-code-block">{% for policy in ExitPolicy_DATA_ARRAY %}{{ policy|e }}
{% endfor %}</pre>
	</section>
</div>

<div class="ts-graph-grid ts-detail-grid">
	<section class="ts-card ts-graph-card">
		<h2>Write bandwidth history</h2>
		<div class="ts-chart-canvas-wrap"><canvas data-chart-endpoint="{{ BandwidthWriteGraphUrl|e('html_attr') }}" data-chart-type="line" data-chart-value-label="Bytes/sec"></canvas></div>
	</section>
	<section class="ts-card ts-graph-card">
		<h2>Read bandwidth history</h2>
		<div class="ts-chart-canvas-wrap"><canvas data-chart-endpoint="{{ BandwidthReadGraphUrl|e('html_attr') }}" data-chart-type="line" data-chart-value-label="Bytes/sec"></canvas></div>
	</section>
	<section class="ts-card">
		<h2>Router flags</h2>
		<table class="ts-mini-table">
			<tbody>
				<tr><th>Authority</th><td class="F{{ FAuthority }}"></td></tr>
				<tr><th>Bad directory</th><td class="F{{ FBadDirectory }}"></td></tr>
				<tr><th>Bad exit</th><td class="F{{ FBadExit }}"></td></tr>
				<tr><th>Exit</th><td class="F{{ FExit }}"></td></tr>
				<tr><th>Fast</th><td class="F{{ FFast }}"></td></tr>
				<tr><th>Guard</th><td class="F{{ FGuard }}"></td></tr>
				<tr><th>Hibernating</th><td class="F{{ FHibernating }}"></td></tr>
				<tr><th>Named</th><td class="F{{ FNamed }}"></td></tr>
				<tr><th>Stable</th><td class="F{{ FStable }}"></td></tr>
				<tr><th>Running</th><td class="F{{ FRunning }}"></td></tr>
				<tr><th>Valid</th><td class="F{{ FValid }}"></td></tr>
				<tr><th>V2Dir</th><td class="F{{ FV2Dir }}"></td></tr>
			</tbody>
		</table>
	</section>
	<section class="ts-card">
		<h2>Router keys</h2>
		<h3>Onion key</h3>
		<pre class="ts-code-block">{{ OnionKey|e }}</pre>
		<h3>Signing key</h3>
		<pre class="ts-code-block">{{ SigningKey|e }}</pre>
	</section>
</div>
{% endif %}
{% endblock %}
