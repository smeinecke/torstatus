{% if SourceFingerprint %}
<dl class="ts-description-list">
	<div><dt>Nickname</dt><dd><a href="router_detail.php?FP={{ SourceFingerprint|e('url') }}">{{ SourceName|e }}</a></dd></div>
	<div><dt>Fingerprint</dt><dd>{{ SourceFingerprint_formatted|e }}</dd></div>
	<div><dt>Country</dt><dd>{% if SourceCountryCode is empty %}Unknown{% else %}<span class="flag flag-country-{{ SourceCountryCode|lower }}"></span> {{ SourceCountryCode|e }}{% endif %}</dd></div>
	<div><dt>Contact</dt><dd>{% if SourceContact is empty %}None Given{% else %}{{ SourceContact|e }}{% endif %}</dd></div>
	<div><dt>Platform</dt><dd>{{ SourcePlatform|e }}</dd></div>
	<div><dt>IP</dt><dd>{{ SourceIP|e }}</dd></div>
	<div><dt>Hostname</dt><dd>{% if SourceIP == SourceHostname %}Unavailable{% else %}{{ SourceHostname|e }}{% endif %}</dd></div>
	<div><dt>ORPort</dt><dd>{{ SourceORPort|e }}</dd></div>
	<div><dt>DirPort</dt><dd>{% if SourceDirPort == 0 %}None{% else %}{{ SourceDirPort|e }}{% endif %}</dd></div>
	<div><dt>Last descriptor</dt><dd>{{ SourceLastDescriptorPublished|e }}</dd></div>
</dl>
<details class="ts-subdetails">
	<summary>Keys and signature</summary>
	<h3>Onion key</h3><pre>{{ SourceOnionKey|e }}</pre>
	<h3>Signing key</h3><pre>{{ SourceSigningKey|e }}</pre>
	<h3>Descriptor signature</h3><pre>{{ SourceDescriptorSignature|e }}</pre>
</details>
{% else %}
<p class="ts-muted">Data source is a client, not a relay, so no detailed relay information is available.</p>
{% endif %}
