<dl class="ts-metric-list">
{% for row in stats_rows %}
	<div class="ts-metric-card">
		<dt>{{ row.label }}</dt>
		<dd><strong>{{ row.count }}</strong> <span>{{ row.percentage }}%</span></dd>
	</div>
{% endfor %}
</dl>
<p class="ts-card-link"><a href="network_detail.php" title="Open network statistic graphs"><i class="ti ti-chart-line" aria-hidden="true"></i>Graphs and details</a></p>
