{% extends "base.html.twig" %}

{% block content %}
<section class="ts-hero">
	<div>
		<p class="ts-eyebrow">Live Tor network status</p>
		<h1>Router directory</h1>
		<p class="ts-muted">Browse relays, inspect flags, filter the result set, and export the current view as CSV.</p>
	</div>
	<div class="ts-hero-actions">
		<button type="button" class="ts-button ts-button-primary" data-dialog-open="filters-dialog" title="Open router sort, search and flag filters">
			<i class="ti ti-adjustments-horizontal" aria-hidden="true"></i>Filters
		</button>
		<a href="query_export.php/Tor_query_EXPORT.csv" class="ts-button ts-button-secondary" title="Download the current router result set as CSV">
			<i class="ti ti-file-type-csv" aria-hidden="true"></i>Export CSV
		</a>
	</div>
</section>

<section class="ts-card ts-status-card">
{% if onion_service|default(false) %}
	<div class="ts-status-icon ts-status-icon-ok"><i class="ti ti-brand-torchain" aria-hidden="true"></i></div>
	<div>
		<h2>You are connected through the onion service</h2>
		<p class="ts-muted">This request reached TorStatus over the Tor network as an onion service.</p>
	</div>
{% elseif PositiveMatch_IP == 1 %}
	<div class="ts-status-icon ts-status-icon-ok"><i class="ti ti-shield-check" aria-hidden="true"></i></div>
	<div>
		<h2>Tor connection detected</h2>
		<p class="ts-muted">Your OR is {{ RemoteIP|e }}.</p>
{% if Count > 0 %}
		<ul class="ts-inline-list">
{% for i in 1..Count %}
			<li>
				Server <a href="router_detail.php?FP={{ TorNodeFP[i]|e('url') }}">{{ TorNodeName[i]|e }}</a>
{% if PositiveMatch_ExitPolicy[i] is defined and PositiveMatch_ExitPolicy[i] == 1 %}
				<span class="ts-pill ts-pill-green">Can exit here</span>
{% elseif PositiveMatch_ExitPolicy[i] is defined and PositiveMatch_ExitPolicy[i] == 0 %}
				<span class="ts-pill ts-pill-red">Cannot exit here</span>
{% endif %}
			</li>
{% endfor %}
		</ul>
{% endif %}
	</div>
{% else %}
	<div class="ts-status-icon ts-status-icon-warn"><i class="ti ti-shield-x" aria-hidden="true"></i></div>
	<div>
		<h2>No Tor connection detected</h2>
		<p class="ts-muted">Your IP address is {{ RemoteIP|e }}.</p>
	</div>
{% endif %}
</section>

<section class="ts-card ts-table-card">
	<div class="ts-section-header">
		<div>
			<h2>Routers</h2>
			<p>{{ total_results }} result{% if total_results != 1 %}s{% endif %}, page {{ pagination.page }} of {{ pagination.total_pages }}</p>
		</div>
		<div class="ts-table-actions">
			<button type="button" class="ts-button ts-button-secondary" data-dialog-open="columns-dialog" title="Choose which columns are shown in the router table">
				<i class="ti ti-columns-3" aria-hidden="true"></i>Columns
			</button>
			<form action="{{ Self|e }}" method="get" class="ts-inline-form">
{% for name, value in query_hidden_inputs %}
				<input type="hidden" name="{{ name|e }}" value="{{ value|e }}">
{% endfor %}
				<label>
					<span>Rows</span>
					<select name="RowsPerPage" id="rows-per-page-select" data-auto-submit>
{% for option in rows_per_page_options %}
						<option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.value }}</option>
{% endfor %}
					</select>
				</label>
				<noscript><button type="submit" class="ts-button ts-button-secondary">Apply</button></noscript>
			</form>
		</div>
	</div>

	{% include '_pagination.html.twig' %}
	<div class="ts-table-scroll">
		{% include '_router_table.html.twig' %}
	</div>
	{% include '_pagination.html.twig' %}
</section>

<div class="ts-dashboard-grid">
	<details class="ts-card ts-dashboard-card ts-dashboard-summary" open>
		<summary><i class="ti ti-chart-pie" aria-hidden="true"></i>Network summary</summary>
		{% include '_index_stats.html.twig' %}
	</details>

	<details class="ts-card ts-dashboard-card" open>
		<summary><i class="ti ti-server" aria-hidden="true"></i>Application server</summary>
		{% include '_index_appserver.html.twig' %}
	</details>

	<details class="ts-card ts-dashboard-card" open>
		<summary><i class="ti ti-info-circle" aria-hidden="true"></i>Opinion source</summary>
		{% include '_index_opinion_source.html.twig' %}
	</details>

	<details class="ts-card ts-dashboard-card" open>
		<summary><i class="ti ti-legend" aria-hidden="true"></i>Legend</summary>
		{% include '_index_legend.html.twig' %}
	</details>
</div>
{% endblock %}

{% block dialogs %}
<dialog class="ts-dialog ts-dialog-wide" id="filters-dialog">
	<form method="dialog" class="ts-dialog-close-form">
		<button class="ts-icon-button" aria-label="Close filters"><i class="ti ti-x" aria-hidden="true"></i></button>
	</form>
	<div class="ts-dialog-header">
		<i class="ti ti-adjustments-horizontal" aria-hidden="true"></i>
		<div>
			<h2>Filters</h2>
			<p>All sort, search and flag filters are submitted as GET parameters.</p>
		</div>
	</div>
	<form action="{{ Self|e }}" method="get" class="ts-form-grid ts-filter-form">
		<input type="hidden" name="Page" value="1">
		<label class="ts-field">
			<span>Sort by</span>
			<select name="SR">
{% for value, label in sort_options %}
				<option value="{{ value }}"{% if sr == value %} selected{% endif %}>{{ label }}</option>
{% endfor %}
			</select>
		</label>
		<label class="ts-field">
			<span>Sort order</span>
			<select name="SO">
				<option value="Asc"{% if so == 'Asc' %} selected{% endif %}>Ascending</option>
				<option value="Desc"{% if so == 'Desc' %} selected{% endif %}>Descending</option>
			</select>
		</label>
		<label class="ts-field">
			<span>Rows per page</span>
			<select name="RowsPerPage">
{% for option in rows_per_page_options %}
				<option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.value }}</option>
{% endfor %}
			</select>
		</label>
		<label class="ts-field">
			<span>Search field</span>
			<select name="CSField">
{% for value, label in search_options %}
				<option value="{{ value }}"{% if CSField == value %} selected{% endif %}>{{ label }}</option>
{% endfor %}
			</select>
		</label>
		<label class="ts-field">
			<span>Search match</span>
			<select name="CSMod">
{% for value, label in search_mod_options %}
				<option value="{{ value }}"{% if CSMod == value %} selected{% endif %}>{{ label }}</option>
{% endfor %}
			</select>
		</label>
		<label class="ts-field">
			<span>Search value</span>
			<input type="search" name="CSInput" maxlength="128" value="{{ CSInput|default('')|e }}" placeholder="Empty disables search">
		</label>
		<fieldset class="ts-field-wide ts-flag-filter-grid">
			<legend>Flag filters</legend>
			<div class="ts-flag-filter-head" aria-hidden="true"><span>Flag</span><span>State</span></div>
{% for name, label in filter_options %}
{% set current = attribute(_context, name)|default('OFF') %}
			<div class="ts-flag-filter-row">
				<span class="ts-flag-filter-name">{{ label }}</span>
				<div class="ts-radio-segment" role="radiogroup" aria-label="{{ label }} filter">
					<label><input type="radio" name="{{ name }}" value="OFF"{% if current == 'OFF' %} checked{% endif %}><span>Any</span></label>
					<label><input type="radio" name="{{ name }}" value="1"{% if current == '1' %} checked{% endif %}><span>Yes</span></label>
					<label><input type="radio" name="{{ name }}" value="0"{% if current == '0' %} checked{% endif %}><span>No</span></label>
				</div>
			</div>
{% endfor %}
		</fieldset>
		<div class="ts-form-actions">
			<a href="{{ Self|e }}" class="ts-button ts-button-secondary">Reset</a>
			<button type="submit" class="ts-button ts-button-primary"><i class="ti ti-check" aria-hidden="true"></i>Apply filters</button>
		</div>
	</form>
</dialog>

<dialog class="ts-dialog ts-dialog-wide" id="columns-dialog"{% if column_dialog_open|default(false) %} data-auto-open="true"{% endif %}>
	<form method="dialog" class="ts-dialog-close-form">
		<button class="ts-icon-button" aria-label="Close columns"><i class="ti ti-x" aria-hidden="true"></i></button>
	</form>
	<div class="ts-dialog-header">
		<i class="ti ti-columns-3" aria-hidden="true"></i>
		<div>
			<h2>Columns</h2>
			<p>Choose which router table columns are visible and adjust their order.</p>
		</div>
	</div>
	<form action="index.php" method="post" class="ts-column-editor">
		<div class="ts-column-pane">
			<h2>Visible columns</h2>
			<select name="CR_ACTIVE" size="20" class="BOXCOLSEL">
{% for value in ColumnList_ACTIVE %}
				<option value="{{ value }}"{% if ((CR_Up is not null or CR_Down is not null) and CR_ACTIVE == value) or (CR_Add is not null and CR_INACTIVE == value) %} selected{% endif %}>{{ value }}</option>
{% endfor %}
			</select>
			<div class="ts-form-actions ts-form-actions-left">
				<button class="ts-button ts-button-secondary" name="Up" type="submit" value="1"><i class="ti ti-arrow-up" aria-hidden="true"></i>Up</button>
				<button class="ts-button ts-button-secondary" name="Down" type="submit" value="1"><i class="ti ti-arrow-down" aria-hidden="true"></i>Down</button>
				<button class="ts-button ts-button-secondary" name="Remove" type="submit" value="1"><i class="ti ti-arrow-right" aria-hidden="true"></i>Remove</button>
			</div>
		</div>
		<div class="ts-column-pane">
			<h2>Available columns</h2>
			<select name="CR_INACTIVE" size="20" class="BOXCOLSEL">
{% for value in ColumnList_INACTIVE %}
				<option value="{{ value }}"{% if CR_Remove is not null and CR_ACTIVE == value %} selected{% endif %}>{{ value }}</option>
{% endfor %}
			</select>
			<div class="ts-form-actions ts-form-actions-left">
				<button class="ts-button ts-button-primary" name="Add" type="submit" value="1"><i class="ti ti-arrow-left" aria-hidden="true"></i>Add column</button>
			</div>
		</div>
	</form>
</dialog>
{% endblock %}
