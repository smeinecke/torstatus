{% extends "base.html.twig" %}

{% block content %}
<section class="ts-hero">
	<div>
		<p class="ts-eyebrow">Network</p>
		<h1>Graphs</h1>
		<p class="ts-muted">Country, uptime, bandwidth, platform and summary graphs generated from the current cache.</p>
	</div>
	<a href="index.php" class="ts-button ts-button-secondary" title="Return to the router list"><i class="ti ti-list-details" aria-hidden="true"></i>Routers</a>
</section>

<div class="ts-graph-grid">
	<section class="ts-card ts-graph-card ts-graph-card-wide">
		<h2>Routers by country code</h2>
		<canvas data-chart-endpoint="graphs.php?type=cc" data-chart-type="bar"></canvas>
	</section>
	<section class="ts-card ts-graph-card ts-graph-card-wide">
		<h2>Exit routers by country code</h2>
		<canvas data-chart-endpoint="graphs.php?type=cc_exit" data-chart-type="bar"></canvas>
	</section>
	<section class="ts-card ts-graph-card ts-graph-card-wide">
		<h2>Routers by uptime</h2>
		<canvas data-chart-endpoint="graphs.php?type=uptime" data-chart-type="bar"></canvas>
	</section>
	<section class="ts-card ts-graph-card">
		<h2>Routers by observed bandwidth</h2>
		<canvas data-chart-endpoint="graphs.php?type=bandwidth" data-chart-type="bar"></canvas>
	</section>
	<section class="ts-card ts-graph-card">
		<h2>Routers by platform</h2>
		<canvas data-chart-endpoint="graphs.php?type=platform" data-chart-type="bar"></canvas>
	</section>
	<section class="ts-card ts-graph-card ts-graph-card-wide">
		<h2>Routers matching specified criteria</h2>
		<canvas data-chart-endpoint="graphs.php?type=summary" data-chart-type="bar"></canvas>
	</section>
</div>
{% endblock %}
