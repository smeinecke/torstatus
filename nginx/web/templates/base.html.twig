<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
{% if noindex|default(false) %}
	<meta name="robots" content="noindex">
{% endif %}
	<title>TorStatus - {{ pageTitle }}</title>
	<link rel="stylesheet" href="css/app.css">
{% block extra_css %}{% endblock %}
	<script>
	(function(){var t=localStorage.getItem('torstatus-theme');if(t==='dark'||t==='light'){document.documentElement.setAttribute('data-theme',t);return;}try{if(window.matchMedia('(prefers-color-scheme: dark)').matches){document.documentElement.setAttribute('data-theme','dark');}}catch(e){}})();
	</script>
</head>

<body class="ts-shell">
<header class="ts-topbar">
	<div class="ts-topbar-inner">
		<a href="/index.php" class="ts-brand" title="Open the TorStatus router list">
			<i class="ti ti-router" aria-hidden="true"></i>
			<span class="ts-brand-title">TorStatus</span>
			<span class="ts-version">{{ version }}</span>
		</a>

		<nav class="ts-nav" aria-label="Primary navigation">
			<a href="/index.php" title="Browse the current Tor router list"><i class="ti ti-list-details" aria-hidden="true"></i><span>Routers</span></a>
			<a href="/tor_exit_query.php" title="Check whether an IP address is a Tor exit"><i class="ti ti-door-exit" aria-hidden="true"></i><span>Exit</span></a>
			<a href="/network_detail.php" title="View network graphs and summary metrics"><i class="ti ti-chart-line" aria-hidden="true"></i><span>Graphs</span></a>
			<a href="/query_export.php/Tor_query_EXPORT.csv" title="Download the current router result set as CSV"><i class="ti ti-file-type-csv" aria-hidden="true"></i><span>CSV</span></a>
		</nav>

		<div class="ts-topbar-actions">
			<button type="button" class="ts-icon-button" id="theme-toggle" title="Toggle light/dark mode" aria-label="Toggle light/dark mode">
				<i class="ti ti-moon" aria-hidden="true" id="theme-icon"></i>
			</button>
{% if showFilterButton|default(false) %}
			<button type="button" class="ts-button ts-button-secondary" data-dialog-open="filters-dialog" title="Open router sort, search and flag filters">
				<i class="ti ti-adjustments-horizontal" aria-hidden="true"></i><span>Filters</span>
			</button>
{% endif %}
			<button type="button" class="ts-button ts-button-primary" data-dialog-open="search-dialog" title="Search routers by nickname">
				<i class="ti ti-search" aria-hidden="true"></i><span>Search</span>
			</button>
		</div>
	</div>
</header>

{% if onion_service|default(false) or Hidden_Service_URL|default(null) %}
<section class="ts-service-banner" aria-label="Connection information">
{% if onion_service|default(false) %}
	<span><i class="ti ti-lock" aria-hidden="true"></i> Onion service connection</span>
{% else %}
	<span><i class="ti ti-shield-lock" aria-hidden="true"></i> Encrypted connection</span>
{% endif %}
{% if Hidden_Service_URL|default(null) %}
	<a href="{{ Hidden_Service_URL|e('html_attr') }}" title="Open the TorStatus onion service">{{ Hidden_Service_URL|e }}</a>
{% endif %}
</section>
{% endif %}

<main class="ts-page">
{% block content %}{% endblock %}
</main>

<footer class="ts-footer">
	{{ footerText|default('')|raw }}
</footer>

<dialog class="ts-dialog" id="search-dialog">
	<form method="dialog" class="ts-dialog-close-form">
		<button class="ts-icon-button" aria-label="Close search"><i class="ti ti-x" aria-hidden="true"></i></button>
	</form>
	<div class="ts-dialog-header">
		<i class="ti ti-search" aria-hidden="true"></i>
		<div>
			<h2>Search routers</h2>
			<p>Search by nickname. Use filters on the router list for advanced fields and flags.</p>
		</div>
	</div>
	<form action="/index.php" method="get" class="ts-form-grid">
		<input type="hidden" name="CSMod" value="Contains">
		<input type="hidden" name="CSField" value="Name">
		<label class="ts-field ts-field-wide">
			<span>Router nickname</span>
			<input type="search" name="CSInput" placeholder="Search for a router" value="{{ CSInput|default('')|e }}" maxlength="128" autofocus>
		</label>
		<div class="ts-form-actions">
			<a href="/index.php" class="ts-button ts-button-secondary">Reset</a>
			<button type="submit" class="ts-button ts-button-primary"><i class="ti ti-search" aria-hidden="true"></i>Search</button>
		</div>
	</form>
</dialog>

{% block dialogs %}{% endblock %}

<script type="module" src="js/app.js"></script>
</body>
</html>
