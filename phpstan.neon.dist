parameters:
    phpVersion: 80500
    level: 5
    paths:
        - nginx/web
    excludePaths:
        - nginx/web/config.php (?)
        - nginx/web/*_graph.php
        - nginx/web/src/Graph/SessionBarGraphRenderer.php
        - nginx/web/src/Graph/BandwidthHistoryGraphRenderer.php
    ignoreErrors:
        -
            message: '#might not be defined#'
            path: nginx/web/*
